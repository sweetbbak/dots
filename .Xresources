! Nsxiv
Nsxiv.bar.font         : MapleMono-Bold:size=20
Nsxiv.bar.background   : #c4a7e7
Nsxiv.bar.foreground   : #232136
Nsxiv.window.foreground: #ea9a97
Nsxiv.window.background: #232136
Nsxiv.mark.foreground  : #c4a7e7

! Sxiv
Sxiv.bar.font  : MapleMono-Bold:size=20 
Sxiv.foreground: #c4a7e7
Sxiv.background: #232136

