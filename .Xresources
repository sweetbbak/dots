! Rose pine moon
*background: #232136 
*foreground: #e0def4

! overlay + muted
*color0: #393552
*color8: #6e6a86

! love
*color1: #eb6f92
*color9: #eb6f92

! foam
*color2: #9ccfd8
*color10: #9ccfd8

! gold
*color3: #f6c177
*color11: #f6c177

! pine
*color4: #3e8fb0
*color12: #3e8fb0

! iris
*color5: #c4a7e7
*color13: #c4a7e7

! rose
*color6: #ea9a97
*color14: #ea9a97

! text
*color7: #e0def4
*color15: #e0def4

