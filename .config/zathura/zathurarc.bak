set guioptions ""
set adjust-open "best-fit"
# set recolor "true"
# set recolor-keephue
set completion-bg "#0D1A34"
set completion-fg "#e4acca"
set completion-group-bg "#0D1A34"
set completion-group-fg "#974576"
set completion-highlight-bg "#e4acca"
set completion-highlight-fg "#0D1A34"
# set recolor-lightcolor "#0D1A34"
# set recolor-darkcolor "#e4acca"
set default-bg "#0D1A34"
set inputbar-bg "#0D1A34"
set inputbar-fg "#e4acca"
set notification-bg "#0D1A34"
set notification-fg "#e4acca"
set notification-error-bg "#524577"
set notification-error-fg "#e4acca"
set notification-warning-bg "#524577"
set notification-warning-fg "#e4acca"
set statusbar-bg "#0D1A34"
set statusbar-fg "#e4acca"
set index-bg "#0D1A34"
set index-fg "#e4acca"
set index-active-bg "#e4acca"
set index-active-fg "#0D1A34"
set render-loading-bg "#0D1A34"
set render-loading-fg "#e4acca"
set smooth-scroll true
set window-title-home-tilde true
set statusbar-basename true
set selection-clipboard clipboard
